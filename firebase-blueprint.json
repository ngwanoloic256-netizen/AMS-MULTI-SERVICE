{
  "$schema": "https://ai.studio/schema/firebase-blueprint.json",
  "collections": {
    "users": {
      "description": "Premium customer files, containing dossier documents status, milestone trackers, and advisor messages",
      "fields": {
        "clientName": {
          "type": "string",
          "description": "Full name of the immigration applicant"
        },
        "email": {
          "type": "string",
          "description": "Primary communication email address"
        },
        "phone": {
          "type": "string",
          "description": "WhatsApp enabled phone number"
        },
        "destination": {
          "type": "string",
          "description": "Target selection country"
        },
        "stepIndex": {
          "type": "number",
          "description": "The dynamic index of current visa progress"
        },
        "documents": {
          "type": "array",
          "description": "Array of files stored securely in dossier vault"
        },
        "notifications": {
          "type": "array",
          "description": "Array of status notifications"
        },
        "adviserName": {
          "type": "string",
          "description": "Senior immigration adviser assigned"
        }
      }
    }
  }
}
